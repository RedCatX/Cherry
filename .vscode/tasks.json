{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile unittests current file",
      "type": "process",
      "command": "dmd",
      "args": [
        "${file}", 
        "-g", 
        "-main", 
        "-unittest",
        "-of=${workspaceFolder}/bin/${fileBasenameNoExtension}-unittests.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}